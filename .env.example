# Copie para .env no servidor local. No Railway, use Variables.

APP_NAME=TermooAPI
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://termoo-api-production-d5e7.up.railway.app

# Logs visíveis no painel do Railway
LOG_CHANNEL=stderr
LOG_LEVEL=error

# Não usamos banco real — só para Laravel iniciar
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
